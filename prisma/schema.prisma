generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String           @id @default(cuid())
  email      String           @unique
  username   String?          @unique
  name       String?
  password   String
  avatar     String?
  role       Role             @default(USER)
  isPremium  Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  bio        String?
  facebook   String?
  instagram  String?
  skillLevel String?
  threads    String?
  tiktok     String?
  website    String?
  comments   Comment[]
  posts      Post[]
  reviews    Review[]
  exercises  UserExercise[]
  progress   UserProgress[]
  vocabulary UserVocabulary[]

  @@map("users")
}

model Post {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  content    String?
  excerpt    String?
  published  Boolean   @default(false)
  featured   Boolean   @default(false)
  views      Int       @default(0)
  authorId   String
  categoryId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]
  tags       PostTag[]
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])

  @@map("posts")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  posts       Post[]

  @@map("categories")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  authorId  String
  postId    String
  parentId  String?
  published Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model VocabularyLevel {
  id                String            @id @default(cuid())
  name              String            @unique
  displayName       String
  description       String?
  order             Int               @unique
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  exercises         Exercise[]
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  topics            VocabularyTopic[]

  @@map("vocabulary_levels")
}

model VocabularyTopic {
  id                String            @id @default(cuid())
  name              String
  displayName       String
  description       String?
  levelId           String
  slug              String
  order             Int
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  level             VocabularyLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([levelId, slug])
  @@unique([levelId, order])
  @@map("vocabulary_topics")
}

model VocabularyEntry {
  id                String           @id @default(cuid())
  german            String
  vietnamese        String
  phonetic          String?
  plural            String?
  type              VocabularyType
  levelId           String
  topicId           String
  exampleGerman     String?
  exampleVietnamese String?
  difficulty        Int              @default(1)
  frequency         Int              @default(0)
  tags              String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exerciseItems     ExerciseItem[]
  userVocabulary    UserVocabulary[]
  level             VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic             VocabularyTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([german, vietnamese, levelId, topicId])
  @@map("vocabulary_entries")
}

model UserVocabulary {
  id            String          @id @default(cuid())
  userId        String
  vocabularyId  String
  status        LearningStatus  @default(NEW)
  correctCount  Int             @default(0)
  totalAttempts Int             @default(0)
  lastReviewed  DateTime?
  nextReview    DateTime?
  difficulty    Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@map("user_vocabulary")
}

model Exercise {
  id            String          @id @default(cuid())
  title         String
  description   String?
  type          ExerciseType
  levelId       String
  difficulty    Int             @default(1)
  timeLimit     Int?
  published     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         ExerciseItem[]
  level         VocabularyLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  userExercises UserExercise[]

  @@map("exercises")
}

model ExerciseItem {
  id            String           @id @default(cuid())
  exerciseId    String
  question      String
  correctAnswer String
  options       String[]
  explanation   String?
  points        Int              @default(1)
  order         Int
  vocabularyId  String?
  exercise      Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry? @relation(fields: [vocabularyId], references: [id])

  @@map("exercise_items")
}

model UserExercise {
  id          String    @id @default(cuid())
  userId      String
  exerciseId  String
  score       Int?
  maxScore    Int?
  timeSpent   Int?
  completed   Boolean   @default(false)
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_exercises")
}

model UserProgress {
  id             String           @id @default(cuid())
  userId         String
  levelId        String
  topicId        String?
  totalWords     Int              @default(0)
  learnedWords   Int              @default(0)
  masteredWords  Int              @default(0)
  streakDays     Int              @default(0)
  totalStudyTime Int              @default(0)
  lastActivity   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  level          VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic          VocabularyTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId, topicId])
  @@map("user_progress")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String?
  amount        Decimal
  currency      String        @default("VND")
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?       @unique
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Review {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  content         String
  rating          Int
  isPublic        Boolean   @default(true)
  isApproved      Boolean   @default(false)
  nextAllowedDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum Role {
  ADMIN
  USER
  USER_PREMIUM
}

enum VocabularyType {
  NOMEN
  VERB
  ADJEKTIV
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  OTHER
}

enum LearningStatus {
  NEW
  LEARNING
  LEARNED
  MASTERED
  NEED_REVIEW
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  TRANSLATION
  LISTENING
  SPEAKING
  VOCABULARY_MATCH
  GRAMMAR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model CrawlJob {
  id             String           @id @default(cuid())
  source         String
  status         CrawlJobStatus   @default(PENDING)
  articlesFound  Int              @default(0)
  articlesAdded  Int              @default(0)
  errorMessage   String?
  startedAt      DateTime         @default(now())
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("crawl_jobs")
}

enum CrawlJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
