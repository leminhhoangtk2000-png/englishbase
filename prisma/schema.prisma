generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  username             String?                @unique
  name                 String?
  password             String
  avatar               String?
  role                 Role                   @default(USER)
  isPremium            Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  bio                  String?
  facebook             String?
  instagram            String?
  skillLevel           String?
  threads              String?
  tiktok               String?
  website              String?
  exercise_completions exercise_completions[]
  articleCompletions   ArticleCompletion[]
  posts                Post[]
  reviews              Review[]
  exercises            UserExercise[]
  progress             UserProgress[]
  vocabulary           UserVocabulary[]

  // Universal Comments Relations
  comments     PageComment[] @relation("UserComments")
  commentLikes CommentLike[] @relation("UserCommentLikes")

  @@map("users")
}

model Post {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  content    String?
  excerpt    String?
  published  Boolean   @default(false)
  featured   Boolean   @default(false)
  views      Int       @default(0)
  authorId   String
  categoryId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tags       PostTag[]
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])

  @@map("posts")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  posts       Post[]

  @@map("categories")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model VocabularyLevel {
  id                String            @id @default(cuid())
  name              String            @unique
  displayName       String
  description       String?
  order             Int               @unique
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  exercises         Exercise[]
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  topics            VocabularyTopic[]

  @@map("vocabulary_levels")
}

model VocabularyTopic {
  id                String            @id @default(cuid())
  name              String
  displayName       String
  description       String?
  levelId           String
  slug              String
  order             Int
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  level             VocabularyLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([levelId, slug])
  @@unique([levelId, order])
  @@map("vocabulary_topics")
}

model VocabularyEntry {
  id                String           @id @default(cuid())
  german            String
  vietnamese        String
  phonetic          String?
  plural            String?
  type              VocabularyType
  levelId           String
  topicId           String
  exampleGerman     String?
  exampleVietnamese String?
  difficulty        Int              @default(1)
  frequency         Int              @default(0)
  tags              String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exerciseItems     ExerciseItem[]
  userVocabulary    UserVocabulary[]
  level             VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic             VocabularyTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([german, vietnamese, levelId, topicId])
  @@map("vocabulary_entries")
}

model UserVocabulary {
  id            String          @id @default(cuid())
  userId        String
  vocabularyId  String
  status        LearningStatus  @default(NEW)
  correctCount  Int             @default(0)
  totalAttempts Int             @default(0)
  lastReviewed  DateTime?
  nextReview    DateTime?
  difficulty    Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@map("user_vocabulary")
}

model Exercise {
  id            String          @id @default(cuid())
  title         String
  description   String?
  type          ExerciseType
  levelId       String
  difficulty    Int             @default(1)
  timeLimit     Int?
  published     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         ExerciseItem[]
  level         VocabularyLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  userExercises UserExercise[]

  @@map("exercises")
}

model ExerciseItem {
  id            String           @id @default(cuid())
  exerciseId    String
  question      String
  correctAnswer String
  options       String[]
  explanation   String?
  points        Int              @default(1)
  order         Int
  vocabularyId  String?
  exercise      Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry? @relation(fields: [vocabularyId], references: [id])

  @@map("exercise_items")
}

model UserExercise {
  id          String    @id @default(cuid())
  userId      String
  exerciseId  String
  score       Int?
  maxScore    Int?
  timeSpent   Int?
  completed   Boolean   @default(false)
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_exercises")
}

model UserProgress {
  id             String           @id @default(cuid())
  userId         String
  levelId        String
  topicId        String?
  totalWords     Int              @default(0)
  learnedWords   Int              @default(0)
  masteredWords  Int              @default(0)
  streakDays     Int              @default(0)
  totalStudyTime Int              @default(0)
  lastActivity   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  level          VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic          VocabularyTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId, topicId])
  @@map("user_progress")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String?
  amount        Decimal
  currency      String        @default("VND")
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?       @unique
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Review {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  content         String
  rating          Int
  isPublic        Boolean   @default(true)
  isApproved      Boolean   @default(false)
  nextAllowedDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model CrawlJob {
  id            String         @id @default(cuid())
  source        String
  status        CrawlJobStatus @default(PENDING)
  articlesFound Int            @default(0)
  articlesAdded Int            @default(0)
  errorMessage  String?
  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("crawl_jobs")
}

model AIProvider {
  id           String         @id @default(cuid())
  name         String         @unique
  displayName  String
  apiKey       String
  baseUrl      String?
  isActive     Boolean        @default(true)
  models       String[]
  defaultModel String?
  maxTokens    Int?
  temperature  Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  testResults  AITestResult[]
  usage        AIUsage[]

  @@map("ai_providers")
}

model AITestResult {
  id           String     @id @default(cuid())
  providerId   String
  model        String
  prompt       String
  response     String?
  success      Boolean
  error        String?
  responseTime Int?
  tokensUsed   Int?
  cost         Float?
  createdAt    DateTime   @default(now())
  provider     AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_test_results")
}

model AIUsage {
  id             String     @id @default(cuid())
  providerId     String
  model          String
  operation      String
  promptTokens   Int        @default(0)
  responseTokens Int        @default(0)
  totalTokens    Int        @default(0)
  cost           Float      @default(0)
  success        Boolean    @default(true)
  error          String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  provider       AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_usage")
}

model AIVocabularyConfig {
  id                  Int      @id @default(1)
  preferredProviderId String?
  fallbackProviderIds String[]
  enableAutoFallback  Boolean  @default(true)
  maxRetries          Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("ai_vocabulary_config")
}

model exercise_views {
  id         String   @id @default(cuid())
  exerciseId String
  userId     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([exerciseId])
  @@index([exerciseId, createdAt])
  @@map("exercise_views")
}

model exercises_master {
  id         String   @id @default(cuid())
  slug       String   @unique // Original path: a1/Horen/Im Restaurant teil 2 - A1
  slugId     String   @unique // Clean ID: a1-horen-im-restaurant-teil-2-a1
  title      String // Exercise title
  level      String // A1, A2, B1, B2
  category   String // Horen, Lesen, Grammatik, etc
  likesCount Int      @default(0) // Cached count from exercise_likes
  viewsCount Int      @default(0) // Cached count from exercise_views
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([level])
  @@index([category])
  @@index([slugId])
  @@index([likesCount])
  @@index([viewsCount])
  @@map("exercises_master")
}

model exercise_likes {
  id         String   @id @default(cuid())
  exerciseId String
  userId     String
  isLiked    Boolean  @default(true) // Like/unlike functionality
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([exerciseId, userId])
  @@index([exerciseId])
  @@map("exercise_likes")
}

model exercise_completions {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String // slug of the exercise
  completedAt DateTime @default(now())

  // Progress tracking
  timeSpent Int? // seconds spent on exercise
  attempts  Int  @default(1)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@map("exercise_completions")
}

// Article completion tracking
model ArticleCompletion {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  completedAt DateTime @default(now())
  timeSpent   Int? // seconds
  attempts    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
  @@map("article_completions")
}

enum Role {
  ADMIN
  USER
  USER_PREMIUM
}

enum VocabularyType {
  NOMEN
  VERB
  ADJEKTIV
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  OTHER
}

enum LearningStatus {
  NEW
  LEARNING
  LEARNED
  MASTERED
  NEED_REVIEW
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  TRANSLATION
  LISTENING
  SPEAKING
  VOCABULARY_MATCH
  GRAMMAR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CrawlJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Universal Comments System Models
model PageComment {
  id          String   @id @default(cuid())
  contentId   String // Unique identifier for each page/lesson (e.g., "a1niveau-grammatik-artikel")
  content     String // Comment content
  authorId    String? // Optional - for registered users
  authorName  String // Display name (for guests or registered users)
  authorEmail String? // Optional email for guest users
  guestId     String? // For guest users (IP-based or localStorage ID)
  isGuest     Boolean  @default(true)
  likes       Int      @default(0)
  parentId    String? // For nested replies
  isDeleted   Boolean  @default(false) // Soft delete
  isApproved  Boolean  @default(true) // For moderation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author        User?         @relation("UserComments", fields: [authorId], references: [id], onDelete: SetNull)
  parent        PageComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies       PageComment[] @relation("CommentReplies")
  likes_records CommentLike[]

  // Indexes for performance
  @@index([contentId])
  @@index([createdAt])
  @@index([parentId])
  @@index([isDeleted, isApproved])
  @@map("page_comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String? // For registered users
  guestId   String? // For guest users
  createdAt DateTime @default(now())

  // Relations
  comment PageComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User?       @relation("UserCommentLikes", fields: [userId], references: [id], onDelete: Cascade)

  // Ensure one like per user/guest per comment
  @@unique([commentId, userId])
  @@unique([commentId, guestId])
  @@map("comment_likes")
}
