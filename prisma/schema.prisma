generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  username               String?                  @unique
  name                   String?
  password               String
  avatar                 String?
  role                   Role                     @default(USER)
  isPremium              Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  bio                    String?
  facebook               String?
  instagram              String?
  skillLevel             String?
  threads                String?
  tiktok                 String?
  website                String?
  comments               Comment[]
  exercise_comment_likes exercise_comment_likes[]
  exercise_comments      exercise_comments[]
  exercise_completions   exercise_completions[]
  articleCompletions     ArticleCompletion[]
  posts                  Post[]
  reviews                Review[]
  exercises              UserExercise[]
  progress               UserProgress[]
  vocabulary             UserVocabulary[]

  @@map("users")
}

model Post {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  content    String?
  excerpt    String?
  published  Boolean   @default(false)
  featured   Boolean   @default(false)
  views      Int       @default(0)
  authorId   String
  categoryId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]
  tags       PostTag[]
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])

  @@map("posts")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  posts       Post[]

  @@map("categories")
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  authorId  String
  postId    String
  parentId  String?
  published Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model VocabularyLevel {
  id                String            @id @default(cuid())
  name              String            @unique
  displayName       String
  description       String?
  order             Int               @unique
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  exercises         Exercise[]
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  topics            VocabularyTopic[]

  @@map("vocabulary_levels")
}

model VocabularyTopic {
  id                String            @id @default(cuid())
  name              String
  displayName       String
  description       String?
  levelId           String
  slug              String
  order             Int
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  userProgress      UserProgress[]
  vocabularyEntries VocabularyEntry[]
  level             VocabularyLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@unique([levelId, slug])
  @@unique([levelId, order])
  @@map("vocabulary_topics")
}

model VocabularyEntry {
  id                String           @id @default(cuid())
  german            String
  vietnamese        String
  phonetic          String?
  plural            String?
  type              VocabularyType
  levelId           String
  topicId           String
  exampleGerman     String?
  exampleVietnamese String?
  difficulty        Int              @default(1)
  frequency         Int              @default(0)
  tags              String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  exerciseItems     ExerciseItem[]
  userVocabulary    UserVocabulary[]
  level             VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic             VocabularyTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([german, vietnamese, levelId, topicId])
  @@map("vocabulary_entries")
}

model UserVocabulary {
  id            String          @id @default(cuid())
  userId        String
  vocabularyId  String
  status        LearningStatus  @default(NEW)
  correctCount  Int             @default(0)
  totalAttempts Int             @default(0)
  lastReviewed  DateTime?
  nextReview    DateTime?
  difficulty    Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@map("user_vocabulary")
}

model Exercise {
  id            String          @id @default(cuid())
  title         String
  description   String?
  type          ExerciseType
  levelId       String
  difficulty    Int             @default(1)
  timeLimit     Int?
  published     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         ExerciseItem[]
  level         VocabularyLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  userExercises UserExercise[]

  @@map("exercises")
}

model ExerciseItem {
  id            String           @id @default(cuid())
  exerciseId    String
  question      String
  correctAnswer String
  options       String[]
  explanation   String?
  points        Int              @default(1)
  order         Int
  vocabularyId  String?
  exercise      Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  vocabulary    VocabularyEntry? @relation(fields: [vocabularyId], references: [id])

  @@map("exercise_items")
}

model UserExercise {
  id          String    @id @default(cuid())
  userId      String
  exerciseId  String
  score       Int?
  maxScore    Int?
  timeSpent   Int?
  completed   Boolean   @default(false)
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_exercises")
}

model UserProgress {
  id             String           @id @default(cuid())
  userId         String
  levelId        String
  topicId        String?
  totalWords     Int              @default(0)
  learnedWords   Int              @default(0)
  masteredWords  Int              @default(0)
  streakDays     Int              @default(0)
  totalStudyTime Int              @default(0)
  lastActivity   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  level          VocabularyLevel  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  topic          VocabularyTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId, topicId])
  @@map("user_progress")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String?
  amount        Decimal
  currency      String        @default("VND")
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?       @unique
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Review {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  content         String
  rating          Int
  isPublic        Boolean   @default(true)
  isApproved      Boolean   @default(false)
  nextAllowedDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model CrawlJob {
  id            String         @id @default(cuid())
  source        String
  status        CrawlJobStatus @default(PENDING)
  articlesFound Int            @default(0)
  articlesAdded Int            @default(0)
  errorMessage  String?
  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("crawl_jobs")
}

model AIProvider {
  id           String         @id @default(cuid())
  name         String         @unique
  displayName  String
  apiKey       String
  baseUrl      String?
  isActive     Boolean        @default(true)
  models       String[]
  defaultModel String?
  maxTokens    Int?
  temperature  Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  testResults  AITestResult[]
  usage        AIUsage[]

  @@map("ai_providers")
}

model AITestResult {
  id           String     @id @default(cuid())
  providerId   String
  model        String
  prompt       String
  response     String?
  success      Boolean
  error        String?
  responseTime Int?
  tokensUsed   Int?
  cost         Float?
  createdAt    DateTime   @default(now())
  provider     AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_test_results")
}

model AIUsage {
  id             String     @id @default(cuid())
  providerId     String
  model          String
  operation      String
  promptTokens   Int        @default(0)
  responseTokens Int        @default(0)
  totalTokens    Int        @default(0)
  cost           Float      @default(0)
  success        Boolean    @default(true)
  error          String?
  metadata       Json?
  createdAt      DateTime   @default(now())
  provider       AIProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("ai_usage")
}

model AIVocabularyConfig {
  id                  Int      @id @default(1)
  preferredProviderId String?
  fallbackProviderIds String[]
  enableAutoFallback  Boolean  @default(true)
  maxRetries          Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("ai_vocabulary_config")
}

model exercise_comment_likes {
  id                String            @id
  userId            String
  commentId         String
  createdAt         DateTime          @default(now())
  exercise_comments exercise_comments @relation(fields: [commentId], references: [id], onDelete: Cascade)
  users             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model exercise_comments {
  id                      String                   @id
  content                 String
  authorId                String
  exerciseId              String
  exerciseUrl             String?
  parentId                String?
  likes                   Int                      @default(0)
  published               Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime
  exercise_comment_likes  exercise_comment_likes[]
  users                   User                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  exercise_comments       exercise_comments?       @relation("exercise_commentsToexercise_comments", fields: [parentId], references: [id])
  other_exercise_comments exercise_comments[]      @relation("exercise_commentsToexercise_comments")
}

model exercise_views {
  id         String   @id @default(cuid())
  exerciseId String
  userId     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([exerciseId])
  @@index([exerciseId, createdAt])
  @@map("exercise_views")
}

model exercise_likes {
  id         String   @id @default(cuid())
  exerciseId String
  userId     String
  isLiked    Boolean  @default(true) // Like/unlike functionality
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([exerciseId, userId])
  @@index([exerciseId])
  @@map("exercise_likes")
}

model exercise_completions {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String // slug of the exercise
  completedAt DateTime @default(now())

  // Progress tracking
  timeSpent Int? // seconds spent on exercise
  attempts  Int  @default(1)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@map("exercise_completions")
}

// Article completion tracking
model ArticleCompletion {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  completedAt DateTime @default(now())
  timeSpent   Int? // seconds
  attempts    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
  @@map("article_completions")
}

enum Role {
  ADMIN
  USER
  USER_PREMIUM
}

enum VocabularyType {
  NOMEN
  VERB
  ADJEKTIV
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  OTHER
}

enum LearningStatus {
  NEW
  LEARNING
  LEARNED
  MASTERED
  NEED_REVIEW
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FILL_BLANK
  TRANSLATION
  LISTENING
  SPEAKING
  VOCABULARY_MATCH
  GRAMMAR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CrawlJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
