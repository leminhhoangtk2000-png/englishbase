# ==================================
# ENVIRONMENT CONFIGURATION
# ==================================
NODE_ENV=development

# ==================================
# DATABASE CONFIGURATION
# ==================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# SECURITY: Never commit the actual DATABASE_URL with credentials to git
DATABASE_URL="postgresql://postgres:postgres@localhost:5555/edu_theme_db?schema=public"

# Optional: Prisma Accelerate for connection pooling
# DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# ==================================
# JWT AUTHENTICATION
# ==================================
# CRITICAL: Must be set in production!
# Generate a strong random secret: openssl rand -base64 32
# This secret is used to sign JWT tokens for user authentication
# If compromised, attackers can forge authentication tokens
JWT_SECRET=your-super-secret-jwt-key-CHANGE-THIS-IN-PRODUCTION

# ==================================
# APPLICATION URLS
# ==================================
NEXT_PUBLIC_APP_URL=http://localhost:9003
NEXTAUTH_URL=http://localhost:9003

# ==================================
# PAYMENT INTEGRATION - SePay
# ==================================
# SePay API credentials for payment processing
# Get these from: https://my.sepay.vn
# SECURITY: Keep these secret, never commit actual values to git
SEPAY_API_TOKEN=your-sepay-api-token
SEPAY_ACCOUNT_NUMBER=your-bank-account-number
SEPAY_WEBHOOK_URL=https://yourdomain.com/api/sepay/webhook

# ==================================
# AI PROVIDERS (Optional)
# ==================================
# Google AI (Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# OpenAI (GPT)
OPENAI_API_KEY=your-openai-api-key

# DeepSeek AI
DEEPSEEK_API_KEY=your-deepseek-api-key

# ==================================
# OAUTH PROVIDERS (Optional)
# ==================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# ==================================
# EMAIL SERVICE (Optional)
# ==================================
# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ==================================
# SECURITY NOTES
# ==================================
# 1. JWT_SECRET: 
#    - MUST be changed in production
#    - Generate strong secret: openssl rand -base64 32
#    - Never use the default value
#    - Changing this will invalidate all existing tokens
#
# 2. DATABASE_URL:
#    - Never commit actual credentials
#    - Use environment variables in production
#    - Consider using connection pooling (Prisma Accelerate)
#    - Rotate passwords regularly
#
# 3. API Keys:
#    - Keep all API keys secret
#    - Rotate keys if compromised
#    - Use different keys for development and production
#    - Monitor API usage for anomalies
#
# 4. HTTPS:
#    - Always use HTTPS in production
#    - Set secure: true for cookies
#    - Enable HSTS headers
#
# 5. Rate Limiting:
#    - Configured in src/lib/rate-limit.ts
#    - Adjust limits based on your needs
#    - Consider using Redis for distributed systems
#
# 6. CORS:
#    - Configure allowed origins in production
#    - Don't allow wildcard (*) origins in production
#
# 7. File Uploads:
#    - Max file size: 5MB (configurable in upload routes)
#    - Allowed types validated by MIME and magic bytes
#    - Files stored in public/uploads/

# ==================================
# DEPLOYMENT CHECKLIST
# ==================================
# Before deploying to production:
# [ ] Change JWT_SECRET to a strong random value
# [ ] Update DATABASE_URL with production credentials
# [ ] Set NODE_ENV=production
# [ ] Enable HTTPS
# [ ] Configure proper CORS origins
# [ ] Set up monitoring and logging
# [ ] Enable rate limiting
# [ ] Test authentication flow
# [ ] Test payment integration
# [ ] Backup database regularly
# [ ] Set up error tracking (e.g., Sentry)

